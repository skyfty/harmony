# WebAssembly / Rust build artifacts and caches
# Rust build output (moved crate into editor/src/wasm)
editor/src/wasm/rust-crate/target/
editor/src/wasm/rust-crate/**/target/

# Generated wasm package (wasm-bindgen / wasm-pack output used by frontend)
editor/src/wasm/pkg/
editor/src/wasm/pkg/**

# Cargo / wasm build outputs for the crate under `editor/wasm`
editor/wasm/target/
editor/wasm/target/**

# Ensure any generated wasm artifacts in src/wasm/pkg are ignored (explicit patterns)
editor/src/wasm/pkg/*.wasm
editor/src/wasm/pkg/*.wasm.d.ts

# wasm-pack / tool caches
.cache/
.cache/**
