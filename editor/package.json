{
  "name": "@harmony/editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm run bootstrap",
    "dev": "vite",
    "bootstrap": "node ../scripts/bootstrap.mjs editor",
    "build": "pnpm run bootstrap && vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate:planning-dem-test-heightmap": "node ./scripts/generate-strict-qgis-test-heightmap.mjs",
    "check:planning-dem-local-tiles": "node ./scripts/planning-dem-local-tiles-regression.mjs",
    "check:planning-dem-metric-space": "node ./scripts/planning-dem-metric-space-regression.mjs",
    "check:planning-dem-png-contract": "node ./scripts/planning-dem-png-contract-regression.mjs",
    "check:terrain-dataset-runtime-lazy": "node ./scripts/terrain-dataset-runtime-lazy-regression.mjs",
    "check:ground-height-sidecar-alignment": "node ./scripts/ground-height-sidecar-alignment-regression.mjs",
    "check:ground-height-sidecar-local-edits": "node ./scripts/ground-height-sidecar-local-edits-regression.mjs",
    "check:infinite-sculpt-chunk-keys": "node ./scripts/infinite-sculpt-chunk-keys-regression.mjs",
    "check:road-collision-compiled": "node ./scripts/road-collision-compiled-regression.mjs"
  },
  "enginewwws": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@harmony/physics-cannon": "file:../physics-cannon",
    "@harmony/physics-ammo": "file:../physics-ammo",
    "@harmony/physics-bridge": "file:../physics-bridge",
    "@harmony/physics-core": "file:../physics-core",
    "@harmony/schema": "file:../schema",
    "@mdi/font": "^7.4.47",
    "@rollup/plugin-replace": "^6.0.3",
    "@types/three": "^0.171.0",
    "@vueuse/core": "^13.9.0",
    "camera-controls": "^3.1.2",
    "cannon-es": "^0.20.0",
    "@vladkrutenyuk/cannon-es-debugger-pro": "^0.2.4",
    "fast-png": "^8.0.0",
    "fflate": "^0.8.2",
    "geotiff": "^3.0.5",
    "meshwalk": "0.0.1",
    "pako": "^2.1.0",
    "pica": "^9.0.1",
    "pinia": "^2.2.6",
    "sass": "^1.93.2",
    "splitpanes": "^4.0.4",
    "three": "^0.172.0",
    "three-geo": "^1.4.5",
    "three-mesh-bvh": "^0.9.1",
    "three-viewport-gizmo": "^2.2.0",
    "v-viewer": "^3.0.0",
    "viewerjs": "^1.11.6",
    "vue": "^3.5.34",
    "vue-router": "^4.5.1",
    "vuetify": "^3.10.5",
    "vuetify_densest": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pako": "^2.0.4",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "utility-types": "^3.11.0",
    "vite": "^7.1.7",
    "vite-plugin-vuetify": "^2.1.2",
    "vue-tsc": "^3.1.0"
  }
