{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "noEmit": true,
    "moduleResolution": "bundler",
    "types": ["vite/client", "vuetify"],
    "paths": {
      "@/*": ["./src/*"],
      "@harmony/utils": ["../utils/src/index.ts"],
      "@harmony/utils/*": ["../utils/src/*"],
      "@schema": ["../schema/index.ts"],
      "@schema/*": ["../schema/*"],
      "@harmony/physics-bridge": ["../physics-bridge/src/index.ts"],
      "@harmony/physics-bridge/*": ["../physics-bridge/src/*"],
      "@harmony/physics-bridge/physicsBackendBridge": ["../physics-bridge/src/physicsBackendBridge.ts"],
      "@harmony/physics-bridge/web": ["../physics-bridge/src/web.ts"],
      "@harmony/physics-bridge/wechat": ["../physics-bridge/src/wechat.ts"],
      "@three-examples/*": [
        "./node_modules/@types/three/examples/jsm/*",
        "./node_modules/three/examples/jsm/*"
      ],
      "three": ["./node_modules/@types/three"],
      "three/*": [
        "./node_modules/@types/three/*",
        "./node_modules/three/*"
      ]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/**/*.d.ts"
  ]
}
