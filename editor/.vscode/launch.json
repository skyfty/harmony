{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Chrome (Editor)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:8088",
      "webRoot": "${workspaceFolder}/editor",
      "sourceMaps": true,
      "preLaunchTask": "npm: dev (editor)",
      "skipFiles": ["/node_modules/**"],
      "sourceMapPathOverrides": {
        "webpack:///*": "${webRoot}/*",
        "*": "${webRoot}/*"
      },
      "resolveSourceMapLocations": [
        "${workspaceFolder}/editor/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "Attach to Chrome (remote)",
      "type": "pwa-chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/editor",
      "sourceMaps": true
    }
  ]
}
