{
  "name": "@harmony/physics-cannon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./debuggerPro": {
      "types": "./dist/debuggerPro.d.ts",
      "default": "./dist/debuggerPro.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm run build"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@harmony/physics-bridge": "file:../physics-bridge",
    "@harmony/physics-core": "file:../physics-core",
    "@vladkrutenyuk/cannon-es-debugger-pro": "^0.2.4",
    "cannon-es": "^0.20.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "typescript": "~5.6.3"
  }
}
