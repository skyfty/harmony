{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "./dist",
    "allowSyntheticDefaultImports": true,
    "importsNotUsedAsValues": "remove",
    "resolveJsonModule": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@harmony/schema": ["./index.ts"],
      "@harmony/schema/*": ["./*"],
      "@harmony/physics-core": ["../physics-core/index.ts"],
      "@harmony/physics-bridge": ["../physics-bridge/index.ts"]
    }
  },
  "include": ["asset-types.ts"],
  "exclude": ["node_modules"]
}
