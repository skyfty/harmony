{
  "name": "@harmony/schema",
  "version": "0.1.0",
  "description": "Shared scene schema definitions for Harmony clients",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:asset-types && node ./node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "build:asset-types": "node ./node_modules/typescript/bin/tsc -p tsconfig.asset-types.json",
    "type-check": "node ./node_modules/typescript/bin/tsc -p tsconfig.build.json --noEmit",
    "type-check:asset-types": "node ./node_modules/typescript/bin/tsc -p tsconfig.asset-types.json --noEmit"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./import": {
      "types": "./dist/import.d.ts",
      "default": "./dist/import.js"
    },
    "./motion": {
      "types": "./dist/motion.d.ts",
      "default": "./dist/motion.js"
    },
    "./vehicleInput": {
      "types": "./dist/vehicleInput.d.ts",
      "default": "./dist/vehicleInput.js"
    },
    "./water": {
      "types": "./dist/water.d.ts",
      "default": "./dist/water.js"
    },
    "./scatter": {
      "types": "./dist/scatter.d.ts",
      "default": "./dist/scatter.js"
    },
    "./overlay": {
      "types": "./dist/overlay.d.ts",
      "default": "./dist/overlay.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./asset-api": {
      "types": "./dist/asset-api.d.ts",
      "default": "./dist/asset-api.js"
    },
    "./terrain-scatter": {
      "types": "./dist/terrain-scatter.d.ts",
      "default": "./dist/terrain-scatter.js"
    }
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@harmony/physics-core": "file:../physics-core",
    "@harmony/physics-bridge": "file:../physics-bridge",
    "@msgpack/msgpack": "^3.1.3",
    "fflate": "^0.8.2",
    "lodash": "^4.17.21",
    "potpack": "^1.0.1",
    "polygon-clipping": "^0.15.7",
    "robust-predicates": "^1.0.3",
    "splaytree": "^3.2.3",
    "three": "^0.172.0",
    "three-nebula": "^10.0.3",
    "three-csm": "^4.2.1",
    "three-mesh-bvh": "^0.9.1",
    "uuid": "^3.4.0"
  },
  "devDependencies": {
    "@harmony/tools": "file:../tools",
    "@types/three": "^0.162.0",
    "typescript": "^5.4.5"
  }
}
