{
  "id": "scenery",
  "displayName": "scenery",
  "version": "0.1.0",
  "description": "Harmony 3D scene viewer (WeChat mini program subpackage)",
  "keywords": [
    "harmony",
    "three",
    "wechat",
    "mini-program"
  ],
  "name": "@harmony/scenery",
  "private": false,
  "license": "UNLICENSED",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm run type-check",
    "type-check": "vue-tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint --ext .ts,.vue common components",
    "lint:fix": "eslint --ext .ts,.vue common components --fix",
    "check": "pnpm run type-check && pnpm run lint",
    "clean": "node -e \"require('node:fs').rmSync('node_modules/.tmp/tsconfig.app.tsbuildinfo', { force: true })\"",
    "prepare": "pnpm run build"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "files": [
    "package.json",
    "components/**/*",
    "common/**/*",
    "composables/**/*",
    "static/**/*",
    "scripts/**/*"
  ],
  "dependencies": {
    "@harmony/schema": "file:../schema",
    "@harmony/utils": "file:../utils",
    "@minisheep/mini-program-polyfill-core": "^1.1.4",
    "three-mesh-bvh": "^0.9.1"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.14",
    "@minisheep/three-platform-adapter": "^2.0.1",
    "@types/three": "^0.171.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "@vue/tsconfig": "^0.7.0",
    "ammojs3": "^0.0.11",
    "eslint": "^8.50.0",
    "eslint-plugin-vue": "^9.10.0",
    "miniprogram-api-typings": "^4.0.5",
    "three": "^0.172.0",
    "typescript": "~5.6.3",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^9.0.0",
    "vue-tsc": "^2.1.10"
  }
}
