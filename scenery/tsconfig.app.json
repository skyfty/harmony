{
  // "extends": "../editor/tsconfig.app.json",
  "include": [
    "common/**/*.ts",
    "common/**/*.d.ts",
    "components/**/*.ts",
    "components/**/*.d.ts",
    "components/**/*.vue",
    "../schema/**/*.ts",
    "../utils/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "common/**/__tests__/*",
    "components/**/__tests__/*"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": [],
    "baseUrl": ".",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@harmony/schema": ["../schema/index.ts"],
      "@harmony/schema/*": ["../schema/*"],
      "@harmony/physics-core": ["../physics-core/src/index.ts"],
      "@harmony/physics-core/*": ["../physics-core/src/*"],
      "@harmony/physics-ammo": ["../physics-ammo/src/index.ts"],
      "@harmony/physics-ammo/*": ["../physics-ammo/src/*"],
      "@harmony/physics-host-wechat": ["../physics-host-wechat/src/index.ts"],
      "@harmony/physics-host-wechat/*": ["../physics-host-wechat/src/*"],
      "@harmony/physics-worker-runtime": ["../physics-worker-runtime/src/index.ts"],
      "@harmony/physics-worker-runtime/*": ["../physics-worker-runtime/src/*"],
      "@harmony/utils": ["../utils/src/index.ts"],
      "@harmony/utils/scene-package-storage": ["../utils/src/scenePackageStorage.ts"],
      "@minisheep/three-platform-adapter": ["node_modules/@minisheep/three-platform-adapter/dist/typings/index.d.ts"],
      "@minisheep/three-platform-adapter/wechat": ["node_modules/@minisheep/three-platform-adapter/dist/typings/wechat/index.d.ts"],
      "@three-examples/*": [
        "node_modules/@types/three/examples/jsm/*",
        "node_modules/three/examples/jsm/*"
      ],
      "three": ["node_modules/@types/three"],
      "three/*": [
        "node_modules/@types/three/*",
        "node_modules/three/*"
      ]
    },
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true
  }
}
