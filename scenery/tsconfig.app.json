{
  // "extends": "../editor/tsconfig.app.json",
  "include": [
    "common/**/*.ts",
    "common/**/*.d.ts",
    "components/**/*.ts",
    "components/**/*.d.ts",
    "components/**/*.vue",
    "../schema/**/*.ts",
    "../utils/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "common/**/__tests__/*",
    "components/**/__tests__/*"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": [],
    "baseUrl": ".",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@harmony/schema": ["../schema/index.ts"],
      "@harmony/schema/*": ["../schema/*"],
      "@harmony/utils": ["../utils/src/index.ts"],
      "@three-examples/*": [
        "node_modules/@types/three/examples/jsm/*",
        "node_modules/three/examples/jsm/*"
      ],
      "three": ["node_modules/@types/three"],
      "three/*": [
        "node_modules/@types/three/*",
        "node_modules/three/*"
      ]
    },
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true
  }
}