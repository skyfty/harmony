{
  "extends": "@vue/tsconfig/tsconfig.json",
  "include": ["src/env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "lib": [
      // Target ES2020 to align with Vite.
      // <https://vitejs.dev/config/build-options.html#build-target>
      // Support for newer versions of language built-ins are
      // left for the users to include, because that would require:
      //   - either the project doesn't need to support older versions of browsers;
      //   - or the project has properly included the necessary polyfills.
      "ES2020",

      "DOM",
      "DOM.Iterable"
    ],
    "types": ["@dcloudio/types", "miniprogram-api-typings", "@uni-ku/bundle-optimizer/client"],
    "composite": true,
    "allowJs": true,
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@/*": ["./src/*"],
      "@schema/*": ["../schema/*"],
      "@harmony/schema": ["./src/pages/scenery/schema/index.ts"],
      "@harmony/schema/*": ["./src/pages/scenery/schema/*"],
      "@harmony/utils": ["./src/pages/scenery/utils/index.ts"],
      "@harmony/scenery-storage": ["./src/pages/scenery/runtime/sceneStorageProxy.ts"],
      "@harmony/utils/http": ["./src/pages/scenery/utils/http.ts"],
      "@harmony/utils/mini-client": ["./src/pages/scenery/utils/miniClient.ts"],
      "@harmony/utils/scene-package-storage": ["./src/pages/scenery/utils/scenePackageStorage.ts"],
      "@harmony/utils/scene-package-fs": ["./src/pages/scenery/utils/scenePackageFs.ts"],
      "@harmony/utils/query": ["./src/pages/scenery/utils/query.ts"],
      "three": ["./src/pages/scenery/three"],
      "three/examples": ["./src/pages/scenery/three/examples"],
      "@three-examples/*": ["./src/pages/scenery/three/examples/jsm/*"],
      "@harmony/physics-ammo": ["./src/pages/physics-ammo/runtime.ts"],
      "@harmony/physics-ammo-source": ["./src/pages/physics-ammo/engine/index.ts"],
      "@harmony/physics-cannon": ["./src/pages/physics-cannon/runtime.ts"],
      "@harmony/physics-cannon-source": ["./src/pages/physics-cannon/engine/index.ts"]
    }
  }
}
