{
  "name": "@harmony/physics-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./physicsBackendBridge": {
      "types": "./dist/physicsBackendBridge.d.ts",
      "default": "./dist/physicsBackendBridge.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "default": "./dist/web.js"
    },
    "./wechat": {
      "types": "./dist/wechat.d.ts",
      "default": "./dist/wechat.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm run build"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@harmony/physics-core": "file:../physics-core"
  },
  "devDependencies": {
    "typescript": "~5.6.3"
  }
}
