{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Debug Editor (Chrome)",
            "url": "http://localhost:8088",
            "webRoot": "${workspaceFolder}/editor",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "vite://*/src/*": "${webRoot}/src/*",
                "vite:///*": "${webRoot}/*",
                "/@fs/*": "/*",
                "/src/*": "${webRoot}/src/*",
                "/*": "${webRoot}/*"
            },
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ]
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Debug Admin (Chrome)",
            "url": "http://localhost:5666",
            "webRoot": "${workspaceFolder}/admin/apps/web-antd",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "vite://*/src/*": "${webRoot}/src/*",
                "vite:///*": "${webRoot}/*",
                "/@fs/*": "/*",
                "/src/*": "${webRoot}/src/*",
                "/*": "${webRoot}/*"
            },
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ]
        },

        {
            "type": "node-terminal",
            "name": "Run Script: dev",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/editor"
        },
        {
            "type": "node-terminal",
            "name": "Run Script: admin dev:antd",
            "request": "launch",
            "command": "pnpm run dev:antd",
            "cwd": "${workspaceFolder}/admin"
        }
    ]
}