{
  "name": "@harmony/tools",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "default": "./dist/vite/index.js"
    }
  },
  "bin": {
    "harmony-tools": "./dist/cli-bin.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev:dem-lab": "vite --config ./dem-lab/vite.config.ts",
    "build:dem-lab": "vite build --config ./dem-lab/vite.config.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepare": "pnpm run build"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "geotiff": "^3.0.5",
    "three": "^0.172.0",
    "svgo": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/three": "^0.171.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.14"
  }
}
