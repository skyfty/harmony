{
  "name": "@harmony/physics-ammo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm run build",
    "check:compiled-ground-offset": "pnpm run build && node ../schema/scripts/fix-esm-extensions.mjs ./dist && node ./scripts/compiled-ground-offset-regression.mjs"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@harmony/physics-bridge": "file:../physics-bridge",
    "@harmony/physics-core": "file:../physics-core"
  },
  "devDependencies": {
    "typescript": "~5.6.3"
  }
}
