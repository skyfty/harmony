# 生产环境配置
NODE_ENV=production
PORT=4000
MULTIUSER_PORT=7645

# docker-compose 内部 Mongo 服务地址
MONGODB_URI=mongodb://mongo:27017/harmony

# 请务必替换为强随机字符串
JWT_SECRET=please-change-me

# 容器内上传路径与公网访问地址
ASSET_STORAGE_PATH=/app/uploads
ASSET_PUBLIC_URL=https://v.touchmagic.cn/uploads

# 允许的前端站点（用于 CORS）
EDITOR_PUBLIC_URL=http://editor.v.touchmagic.cn

# 默认测试账号（可自定义，也可留空）
EDITOR_USER_USERNAME=editor
EDITOR_USER_PASSWORD=editor123
EDITOR_USER_DISPLAY_NAME=Editor 用户

# uploader 专用账号（请设置为强密码）
UPLOADER_USER_USERNAME=uploader
UPLOADER_USER_PASSWORD=uploader123
UPLOADER_USER_DISPLAY_NAME=资源上传员

# 小程序默认测试账号（仅用于体验环境，可按需调整或禁用）
MINIPROGRAM_TEST_USER_USERNAME=test
MINIPROGRAM_TEST_USER_PASSWORD=test1234
MINIPROGRAM_TEST_USER_DISPLAY_NAME=Test Account

# 微信小程序授权登录（code2session）
