# 开发环境配置
NODE_ENV=development
PORT=4000
MULTIUSER_PORT=7645

# MongoDB 本地连接（默认使用 docker-compose 暴露的 27018 端口）
MONGODB_URI=mongodb://localhost:27017/harmony

# 开发环境使用的 JWT 密钥（请按需修改）
JWT_SECRET=dev-secret-change-me

# 上传路径与访问地址
ASSET_STORAGE_PATH=./uploads
ASSET_PUBLIC_URL=http://localhost:4000/uploads

# 允许的前端站点（开发模式下指向本地 editor）
EDITOR_PUBLIC_URL=http://localhost:5173

# 默认测试账号（用于 seed 脚本，可根据需要调整）
EDITOR_USER_USERNAME=editor
EDITOR_USER_PASSWORD=editor123
EDITOR_USER_DISPLAY_NAME=Editor 用户

# uploader 独立登录账号
UPLOADER_USER_USERNAME=uploader
UPLOADER_USER_PASSWORD=uploader123
UPLOADER_USER_DISPLAY_NAME=资源上传员

# 小程序默认测试账号配置（仅用于测试环境登录）
MINIPROGRAM_TEST_USER_USERNAME=test
MINIPROGRAM_TEST_USER_PASSWORD=test1234
MINIPROGRAM_TEST_USER_DISPLAY_NAME=Test Account

# 微信小程序授权登录（code2session）
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=
WECHAT_API_BASE_URL=https://api.weixin.qq.com

# 微信支付（开发）
WECHAT_PAY_ENABLED=false
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_NOTIFY_URL=http://localhost:4000/wechat/pay/notify
WECHAT_PAY_BASE_URL=https://api.mch.weixin.qq.com
WECHAT_PAY_PLATFORM_PUBLIC_KEY=

# 本地联调回调（仅开发可开）
WECHAT_PAY_CALLBACK_SKIP_VERIFY_IN_DEV=true
WECHAT_PAY_MOCK_PLATFORM_PRIVATE_KEY=

# OpenAI 相关配置（如不需要可留空）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_ORG=
OPENAI_PROJECT=
