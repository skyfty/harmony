{
  "info": {
    "name": "Harmony Vehicle APIs",
    "_postman_id": "f2d04b68-c543-4c1a-a4dc-7ef95f3f6801",
    "description": "Vehicle / UserVehicle APIs for admin backend and mini program usage.",
