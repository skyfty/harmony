{
  "name": "@harmony/utils",
  "version": "1.0.0",
  "private": true,
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "prepare": "pnpm run build"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./http": {
      "import": "./dist/http.js",
      "default": "./dist/http.js",
      "types": "./dist/http.d.ts"
    },
    "./mini-client": {
      "import": "./dist/miniClient.js",
      "default": "./dist/miniClient.js",
      "types": "./dist/miniClient.d.ts"
    },
    "./query": {
      "import": "./dist/query.js",
      "default": "./dist/query.js",
      "types": "./dist/query.d.ts"
    },
    "./scene-package-storage": {
      "import": "./dist/scenePackageStorage.js",
      "default": "./dist/scenePackageStorage.js",
      "types": "./dist/scenePackageStorage.d.ts"
    },
    "./scene-package-fs": {
      "import": "./dist/scenePackageFs.js",
      "default": "./dist/scenePackageFs.js",
      "types": "./dist/scenePackageFs.d.ts"
    }
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "rimraf": "^3.0.2"
  }
}
